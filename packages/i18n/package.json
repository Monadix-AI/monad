{
  "name": "@monad/i18n",
  "version": "0.0.0",
  "dependencies": {},
  "devDependencies": {
    "@monad/config": "workspace:*",
    "@types/bun": "^1.3.14"
  },
  "exports": {
    ".": "./src/index.ts",
    "./browser": "./src/browser.ts",
    "./messages": "./src/messages.ts",
    "./locale-dir": "./src/locale-dir.ts"
  },
  "imports": {
    "#messages": {
      "monad-typecheck": "./src/messages.typecheck.ts",
      "default": "./src/messages.ts"
    },
    "#catalog-types": {
      "monad-typecheck": "./src/catalog-types.typecheck.ts",
      "default": "./src/catalog-types.ts"
    }
  },
  "module": "src/index.ts",
  "private": true,
  "scripts": {
    "i18n:check": "bun ../../scripts/i18n.ts --check",
    "i18n:types": "bun ../../scripts/i18n.ts --write-if-stale",
    "i18n:types:force": "bun ../../scripts/i18n.ts --write",
    "lint": "biome check .",
    "start:dev": "bun ../../scripts/i18n.ts --watch",
    "test": "bun run i18n:types && bun ../../scripts/bun-test.ts test/ --only-failures",
    "test:loud": "bun run i18n:types && bun ../../scripts/bun-test.ts test/ --loud",
    "test:unit": "bun run i18n:types && bun ../../scripts/bun-test.ts test/unit/ --only-failures",
    "test:unit:loud": "bun run i18n:types && bun ../../scripts/bun-test.ts test/unit/ --loud",
    "typecheck": "tsc -p tsconfig.typecheck.json --noEmit"
  },
  "sideEffects": false,
  "type": "module"
}
