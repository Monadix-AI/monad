{
  "name": "@monad/logger",
  "version": "0.0.0",
  "dependencies": {
    "pino": "^10.3.1",
    "pino-pretty": "^13.1.3"
  },
  "devDependencies": {
    "@monad/config": "workspace:*",
    "@types/bun": "^1.3.14"
  },
  "exports": {
    ".": "./src/index.ts"
