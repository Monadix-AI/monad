{
  "name": "@monad/sandbox",
  "version": "0.0.0",
  "bin": {
    "msr": "src/cli.ts"
  },
  "dependencies": {
    "@monad/logger": "workspace:*",
    "@monad/sdk-atom": "workspace:*",
    "node-forge": "^1.4.0"
  },
  "devDependencies": {
    "@types/bun": "^1.3.14",
    "@types/node-forge": "^1.3.14"
  },
  "exports": {
    ".": "./src/index.ts",
    "./launchers/bwrap": "./src/launchers/bwrap.ts",
    "./launchers/landlock": "./src/launchers/landlock.ts",
    "./launchers/seatbelt": "./src/launchers/seatbelt.ts",
    "./launchers/win32": "./src/launchers/win32.ts",
    "./launchers/win32-appcontainer": "./src/launchers/win32-appcontainer.ts"
  },
  "license": "MIT",
  "module": "src/index.ts",
  "private": true,
  "scripts": {
    "lint": "biome check .",
    "test": "bun ../../scripts/bun-test.ts test/ --only-failures",
    "test:loud": "bun ../../scripts/bun-test.ts test/ --loud",
    "test:unit": "bun ../../scripts/bun-test.ts test/unit/ --only-failures",
    "test:unit:loud": "bun ../../scripts/bun-test.ts test/unit/ --loud",
    "typecheck": "tsc --noEmit"
  },
  "type": "module"
}
