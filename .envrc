# Auto-switch bun to the version pinned in "packageManager" in package.json.
# Requires: direnv (https://direnv.net) + mise (https://mise.jdx.dev)
#   macOS:  brew install direnv mise
#   Linux:  https://direnv.net/docs/installation.html + https://mise.jdx.dev/getting-started.html
# Then run: direnv allow   (once per clone)

ver=$(grep -o '"packageManager"[^"]*"bun@[^"]*"' package.json 2>/dev/null \
      | grep -o 'bun@[^"]*' | cut -d@ -f2)

if [ -z "$ver" ]; then
  log_error "bun: no packageManager pin found in package.json"
  exit 1
fi

bun_bin="${MISE_DATA_DIR:-$HOME/.local/share/mise}/installs/bun/$ver/bin"

if [ ! -d "$bun_bin" ]; then
  if ! command -v mise >/dev/null 2>&1; then
    log_error "mise not found. Install: brew install mise  (or see https://mise.jdx.dev)"
    exit 1
  fi
  log_status "bun: downloading $ver..."
  mise install "bun@$ver"
fi

PATH_add "$bun_bin"
log_status "bun: $ver"
