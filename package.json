{
  "name": "monad",
  "description": "Local, single-user daemon for running agentic sessions, with a CLI and web UI.",
  "version": "0.0.2",
  "author": "Monadix Labs, Inc.",
  "bugs": {
    "url": "https://github.com/Monadix-AI/monad/issues"
  },
  "config": {
    "commitizen": {
      "path": "@commitlint/cz-commitlint"
    }
  },
  "dependencies": {},
  "devDependencies": {
    "@biomejs/biome": "^2.5.4",
    "@commitlint/cli": "^21.2.1",
    "@commitlint/config-conventional": "^21.2.0",
    "@commitlint/cz-commitlint": "^21.2.0",
    "@commitlint/format": "^21.2.0",
    "@commitlint/types": "^21.2.0",
    "@evilmartians/lefthook": "^2.1.10",
    "@inlang/paraglide-js": "^2.21.0",
    "@types/bun": "^1.3.14",
    "commitizen": "^4.3.2",
    "knip": "^6.27.0",
    "rulesync": "^14.0.1",
    "syncpack": "^15.3.2",
    "turbo": "^2.10.5",
    "typescript": "^7.0.2"
  },
  "homepage": "https://github.com/Monadix-AI/monad#readme",
  "license": "MIT",
  "packageManager": "bun@1.3.14",
  "private": true,
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Monadix-AI/monad.git"
  },
  "scripts": {
    "agents:check": "rulesync generate --check",
    "agents:local": "bun run scripts/sync-agents-local.ts",
    "agents:sync": "rulesync generate",
    "build": "bun run i18n:types && turbo run build",
    "build-storybook:ui": "bun run --cwd packages/ui build-storybook",
    "build-storybook:web": "bun run --cwd apps/web build-storybook",
    "build:release": "bun run i18n:types && bun run scripts/build-release.ts",
    "check:deps": "bun run scripts/check-deps.ts",
    "check:test-assertions": "bun run scripts/check-test-assertions.ts",
    "clean": "bunx --bun rimraf --glob \"**/node_modules\" \"**/.turbo\" \"**/.next\" \"**/dist\" \"**/out\"",
    "db:bundle": "bun run --cwd apps/monad db:bundle",
    "db:check": "bun run --cwd apps/monad db:check",
    "db:drift": "bun run --cwd apps/monad db:drift",
    "db:generate": "bun run --cwd apps/monad db:generate",
    "db:generate:custom": "bun run --cwd apps/monad db:generate:custom",
    "deploy:local": "bash scripts/deploy-local.sh",
    "dev": "bun run scripts/dev-prep.ts",
    "dev:doctor": "bun run scripts/dev-doctor.ts",
    "docker:shell": "docker buildx bake --file docker/docker-bake.hcl shell && docker run --rm -it -e PATH=\"/opt/monad/local-bin:/usr/local/sbin:/usr/local/bin:/usr/sbin:/usr/bin:/sbin:/bin\" monad-shell:dev bash",
    "docker:test:e2e": "docker buildx bake --file docker/docker-bake.hcl --progress=plain test-e2e",
    "docker:test:e2e:deps": "docker buildx build --file docker/Dockerfile.e2e-deps --target test --progress=plain .",
    "docker:test:e2e:live": "docker buildx bake --file docker/docker-bake.hcl --load test-e2e-live && docker run --rm -e OPENROUTER_API_KEY -e MONAD_LIVE_MODEL monad-e2e-live:dev /e2e-live.sh",
    "docker:test:install": "docker buildx bake --file docker/docker-bake.hcl --progress=plain test-install",
    "docker:test:install:musl": "docker buildx bake --file docker/docker-bake.hcl --progress=plain test-install-musl",
    "docker:test:unit": "docker buildx bake --file docker/docker-bake.hcl --progress=plain test-unit",
    "i18n:check": "bun run scripts/i18n.ts --check",
    "i18n:types": "bun run scripts/i18n.ts --write-if-stale",
    "i18n:types:force": "bun run scripts/i18n.ts --write",
    "knip": "knip-bun",
    "lint": "biome check --write",
    "lint:check": "biome check .",
    "postinstall": "bun run scripts/dev-init.ts",
    "quality:check": "bun run scripts/quality-gate.ts check",
    "quality:fix": "bun run scripts/quality-gate.ts fix",
    "quality:precommit": "bun run scripts/quality-gate.ts precommit",
    "setup": "bun run scripts/dev-init.ts",
    "smoke:mesh-agent-managed": "bun run scripts/mesh-agent-managed-smoke.ts",
    "storybook": "bun run storybook:web",
    "storybook:ui": "bun run --cwd packages/ui storybook",
    "storybook:web": "bun run --cwd apps/web storybook",
    "syncpack:format": "syncpack format",
    "syncpack:lint": "syncpack lint",
    "test": "bun run i18n:types && turbo run test --output-logs=errors-only",
    "test:e2e": "bun run test:e2e:daemon && bun run test:e2e:web",
    "test:e2e:binary": "bash scripts/test/e2e.sh",
    "test:e2e:daemon": "bun run test:e2e:hermetic",
    "test:e2e:daemon:loud": "bun run i18n:types && turbo run test:e2e:loud --filter=@monad/monad",
    "test:e2e:hermetic": "bun run i18n:types && turbo run test:e2e --filter=@monad/monad --output-logs=errors-only",
    "test:e2e:loud": "bun run test:e2e:daemon:loud && bun run test:e2e:web:loud",
    "test:e2e:web": "bun run --cwd apps/web test:e2e",
    "test:e2e:web:loud": "bun run --cwd apps/web test:e2e:loud",
    "test:install": "bash scripts/test/install-test.sh",
    "test:install:fake": "bash scripts/test/install-script-fake-e2e.sh",
    "test:install:win": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/test/install-test.ps1",
    "test:install:win:fake": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/test/install-script-fake-e2e.ps1",
    "test:loud": "bun run i18n:types && turbo run test:loud",
    "test:unit": "bun run i18n:types && turbo run test:unit --output-logs=errors-only && bun test scripts/test/unit/",
    "test:unit:loud": "bun run i18n:types && turbo run test:unit:loud",
    "typecheck": "bun run typecheck:prepare && bun run typecheck:check",
    "typecheck:check": "tsc --noEmit && turbo run typecheck",
    "typecheck:prepare": "bun run scripts/typecheck-prepare.ts"
  },
  "type": "module",
  "workspaces": [
    "apps/*",
    "packages/*"
  ]
}
