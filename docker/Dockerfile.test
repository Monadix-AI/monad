# syntax=docker/dockerfile:1
#
# Multi-stage test pipeline — nothing touches the host.
#
#   Stage 1 (builder): compile all binaries + Next.js standalone
#   Stage 2 (tester):  run install.sh in a fresh Debian environment + smoke tests
#
# Platform defaults to the host's native architecture (fast, no QEMU emulation).
# Override for CI:  docker build --platform linux/amd64 ...
#
# Usage:
#   bun run docker:test:install
#   PLATFORM=linux/amd64 bun run docker:test:install   # x64 cross-compile on Apple Silicon (slow)

# ── Stage 1: build ────────────────────────────────────────────────────────────

FROM oven/bun:1 AS builder

WORKDIR /workspace

# Layer-cache bun install: copy manifests first, full source second.
COPY bun.lock package.json turbo.jsonc ./
COPY --parents apps/*/package.json clients/*/package.json packages/*/package.json ./

RUN BUN_RETRY=3 bun install

COPY . .

RUN bun run scripts/build-release.ts

# ── Stage 2: test ─────────────────────────────────────────────────────────────

FROM debian:bookworm-slim AS tester

RUN apt-get update \
  && apt-get install -y --no-install-recommends ca-certificates curl \
  && rm -rf /var/lib/apt/lists/*

# Copy install script and the built tarball (arch-agnostic glob)
COPY scripts/install.sh /install.sh
RUN chmod +x /install.sh
COPY --from=builder /workspace/dist/monad-*-linux-*.tar.gz /dist/

# Run the installer — pick whichever tarball was built (exactly one per arch)
RUN set -e; \
  tarball=$(ls /dist/monad-*-linux-*.tar.gz | head -1); \
  echo "[docker-test] Installing: $(basename $tarball)"; \
  MONAD_TARBALL="$tarball" \
  MONAD_SKIP_VERIFY=1 \
  MONAD_INSTALL_DIR=/opt/monad \
  MONAD_BIN_DIR=/opt/monad/local-bin \
  MONAD_HOME=/opt/monad/home \
  MONAD_NO_PATH_MODIFY=1 \
  bash /install.sh

# ── Smoke tests ────────────────────────────────────────────────────────────────

RUN echo "=== monad CLI ===" \
  && /opt/monad/local-bin/monad --help | head -8

RUN echo "=== installed (one binary + name-symlinks) ===" \
  && ls -lh /opt/monad/local-bin/

RUN echo "=== monad home (isolated) ===" \
  && ls /opt/monad/home/

RUN echo "All checks passed."
