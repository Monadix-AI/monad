{
  "name": "@monad/web",
  "version": "0.0.0",
  "dependencies": {
    "@hookform/resolvers": "^5.4.0",
    "@hugeicons/core-free-icons": "^4.2.2",
    "@hugeicons/react": "^1.1.9",
    "@monad/atoms": "workspace:*",
    "@monad/client": "workspace:*",
    "@monad/client-rtk": "workspace:*",
    "@monad/config": "workspace:*",
    "@monad/home": "workspace:*",
    "@monad/i18n": "workspace:*",
    "@monad/logger": "workspace:*",
    "@monad/protocol": "workspace:*",
    "@monad/sdk-experience": "workspace:*",
    "@monad/ui": "workspace:*",
    "@monad/utils": "workspace:*",
    "@tanstack/hotkeys": "0.8.0",
    "@tanstack/react-hotkeys": "^0.10.0",
    "@tanstack/react-router": "^1.170.17",
    "@tanstack/react-router-devtools": "^1.167.0",
    "@xyflow/react": "^12.11.2",
    "ghostty-web": "^0.4.0",
    "motion": "^12.42.2",
    "radix-ui": "^1.6.2",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-hook-form": "^7.81.0",
    "react-redux": "^9.3.0",
    "shiki": "^4.3.1",
    "three": "^0.185.1",
    "zod": "^4.4.3",
    "zustand": "^5.0.14"
  },
  "devDependencies": {
    "@monad/monad": "workspace:*",
    "@playwright/test": "^1.61.1",
    "@tailwindcss/postcss": "^4.3.2",
    "@tanstack/router-plugin": "^1.168.19",
    "@types/bun": "^1.3.14",
    "@types/node": "^26.1.0",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@types/three": "^0.185.0",
    "@vitejs/plugin-react": "^5.1.2",
    "postcss": "^8.5.16",
    "tailwindcss": "^4.3.2",
    "tw-animate-css": "^1.4.0",
    "vite": "npm:rolldown-vite@7.3.1"
  },
  "exports": {
    "./server": "./server/index.ts"
  },
  "imports": {
    "#/*": [
      "./src/*",
      "./src/*.ts",
      "./src/*.tsx",
      "./src/*/index.ts",
      "./src/*/index.tsx",
      "./*",
      "./*.ts",
      "./*.tsx",
      "./*/index.ts",
      "./*/index.tsx"
    ]
  },
  "private": true,
  "scripts": {
    "build": "bunx --bun vite build",
    "dev": "LAUNCH_EDITOR=${LAUNCH_EDITOR:-/usr/local/bin/code} bunx --bun vite --host 0.0.0.0 --port ${WEB_PORT:-3000}",
    "export": "bunx --bun vite build",
    "lint": "biome check .",
    "start": "bunx --bun vite preview --host 0.0.0.0 --port ${WEB_PORT:-3000}",
    "start:dev": "LAUNCH_EDITOR=${LAUNCH_EDITOR:-/usr/local/bin/code} bunx --bun vite --host 0.0.0.0 --port ${WEB_PORT:-3000}",
    "test": "bun ../../scripts/bun-test.ts test/unit/ --only-failures",
    "test:e2e": "playwright test --reporter=dot",
    "test:e2e:loud": "playwright test --reporter=list",
    "test:loud": "bun ../../scripts/bun-test.ts test/ --loud",
    "test:unit": "bun ../../scripts/bun-test.ts test/unit/ --only-failures",
    "test:unit:loud": "bun ../../scripts/bun-test.ts test/unit/ --loud",
    "typecheck": "tsgo --noEmit"
  },
  "type": "module"
}
