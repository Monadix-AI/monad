{
  "extends": "@monad/config/tsconfig.base.json",
  "compilerOptions": {
    "lib": ["ESNext", "DOM", "DOM.Iterable"],
    "module": "ESNext",
    "allowArbitraryExtensions": true,
    "noUncheckedIndexedAccess": false,
    "jsx": "react-jsx",
    "paths": {
      "#/*": ["./*", "../monad/src/*"],
      "@monad/monad": ["../monad/src/public-api.ts"],
      "@monad/monad/start": ["../monad/src/public-api.ts"],
      "@monad/monad/log-maintenance": ["../monad/src/public-log-maintenance.ts"]
    },
    "plugins": [
      {
        "name": "next"
      }
    ],
    "allowJs": true,
    "incremental": true
  },
  "include": ["**/*.ts", "**/*.tsx", "next-env.d.ts", ".next/types/**/*.ts", ".next/dev/types/**/*.ts"],
  "exclude": ["node_modules", ".next"]
}
