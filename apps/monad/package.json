{
  "name": "@monad/monad",
  "version": "0.0.0",
  "dependencies": {
    "@a2a-js/sdk": "^0.3.13",
    "@agentclientprotocol/sdk": "^1.1.0",
    "@arizeai/openinference-semantic-conventions": "^2.5.0",
    "@arizeai/openinference-vercel": "^3.1.0",
    "@dicebear/core": "^10.3.0",
    "@dicebear/styles": "^10.2.0",
    "@elysiajs/swagger": "^1.3.1",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@monad/atoms": "workspace:*",
    "@monad/home": "workspace:*",
    "@monad/i18n": "workspace:*",
    "@monad/logger": "workspace:*",
    "@monad/protocol": "workspace:*",
    "@monad/sdk-atom": "workspace:*",
    "@monad/utils": "workspace:*",
    "@opentelemetry/api": "^1.9.1",
    "@opentelemetry/context-async-hooks": "^2.9.0",
    "@opentelemetry/exporter-metrics-otlp-proto": "^0.220.0",
    "@opentelemetry/exporter-trace-otlp-proto": "^0.220.0",
    "@opentelemetry/resources": "^2.9.0",
    "@opentelemetry/sdk-metrics": "^2.9.0",
    "@opentelemetry/sdk-trace-base": "^2.9.0",
    "@opentelemetry/semantic-conventions": "^1.41.1",
    "drizzle-orm": "^0.45.2",
    "elysia": "^1.4.29",
    "mem0ai": "^3.0.13",
    "partial-json": "^0.1.7",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@monad/config": "workspace:*",
    "@monad/monad-power-pack": "workspace:*",
    "openai": "^6.45.0"
  },
  "exports": {
    ".": {
      "types": "./dist/main.d.ts",
      "monad-typecheck": "./dist/main.d.ts",
      "default": "./src/main.ts"
    },
    "./start": {
      "types": "./dist/main.d.ts",
      "monad-typecheck": "./dist/main.d.ts",
      "default": "./src/main.ts"
    },
    "./log-maintenance": {
      "types": "./dist/services/log-maintenance.d.ts",
      "monad-typecheck": "./dist/services/log-maintenance.d.ts",
      "default": "./src/services/log-maintenance.ts"
    }
  },
  "module": "src/main.ts",
  "private": true,
  "scripts": {
    "build": "tsc --build --clean tsconfig.build.json && tsc --build tsconfig.build.json",
    "devtools": "bunx @ai-sdk/devtools",
    "lint": "biome check .",
    "start": "bun src/main.ts",
    "start:dev": "NODE_ENV=development bun --env-file=../../.env.local --watch src/main.ts --dev",
    "test": "bun ../../scripts/bun-test.ts test/ --only-failures",
    "test:e2e": "bun ../../scripts/bun-test.ts test/e2e/ --only-failures",
    "test:e2e:loud": "bun ../../scripts/bun-test.ts test/e2e/ --loud",
    "test:loud": "bun ../../scripts/bun-test.ts test/ --loud",
    "test:unit": "bun ../../scripts/bun-test.ts test/unit/ --only-failures",
    "test:unit:loud": "bun ../../scripts/bun-test.ts test/unit/ --loud",
    "typecheck": "tsgo --noEmit"
  },
  "type": "module"
}
