# monad dev environment — copy auto-created as .env.local by `bun run dev`.
# This file holds only infra (data dir + ports). The provider, model, API key, and bot token
# live in config.init.json — copy config.init.json.template to config.init.json and fill it in
# (`bun run dev` scaffolds it for you).

# Root directory for daemon state (SQLite, logs, etc.).
# Defaults to .dev/.monad inside the project directory (set by scripts/dev-init.ts).
# Override to run a fully-isolated instance: MONAD_HOME=/path/to/other/dir
MONAD_HOME=

# XDG base directories (Linux, fresh installs only — MONAD_HOME overrides all of these).
# Leave unset to use the spec defaults (~/.config, ~/.local/share, ~/.cache, ~/.local/state).
# XDG_CONFIG_HOME=/path/to/config
# XDG_DATA_HOME=/path/to/data
# XDG_CACHE_HOME=/path/to/cache
# XDG_STATE_HOME=/path/to/state
# XDG_RUNTIME_DIR=/path/to/runtime

# Editor used by `monad config edit` (falls back to vi).
EDITOR=
VISUAL=

# Pager for long CLI output (session show, etc.); falls back to `less -FIRX`.
PAGER=

# Daemon and web ports.
#
# scripts/dev-init.ts auto-assigns per-worktree development ports into .env.local
# (derived from the checkout path) so multiple git worktrees can run `bun dev` at once without
# port clashes — leave them unset here and let setup-dev fill them, or pin a value to override:
#   MONAD_PORT  daemon TCP port; overrides config.json's network.port for the daemon AND its
#               clients (so they stay in sync). Defaults to 52749 when unset.
#   WEB_PORT    Vite dev server port. Defaults to 3000 when unset.
#
# The remote-access token lives in config.json (network.remoteAccess.token). To target a
# REMOTE daemon instead, set:
#   MONAD_URL=http://remote-host:52749
#   MONAD_TOKEN=<bearer-token>

# Turbo remote cache credentials. These are only needed when you want local turbo
# runs or CI to talk to Turbo Cloud.
#   TURBO_TEAM=<team id>
#   TURBO_TOKEN=<turbo token>
#   TURBO_REMOTE_CACHE_SIGNATURE_KEY=<32+ byte signing key>
